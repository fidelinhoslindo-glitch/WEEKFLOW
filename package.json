{
  "name": "weekflow",
  "version": "2.5.0",
  "description": "Organize your week, find your flow.",
  "author": "WeekFlow",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "electron:publish": "vite build && electron-builder --win --publish always",
    "record": "node scripts/record-demo.cjs"
  },
  "build": {
    "appId": "app.weekflow.desktop",
    "productName": "WeekFlow",
    "publish": {
      "provider": "github",
      "owner": "fidelinhoslindo-glitch",
      "repo": "WEEKFLOW"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  },
  "dependencies": {
    "@stripe/stripe-js": "^8.11.0",
    "@supabase/supabase-js": "^2.43.0",
    "electron-updater": "^6.8.3",
    "firebase": "^12.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0",
    "wait-on": "^9.0.4"
  }
}
